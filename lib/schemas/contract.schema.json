{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["schemaVersion", "goal", "inScope", "acceptanceCriteria", "riskLevel"],
  "if": {
    "properties": { "schemaVersion": { "const": "3.2" } }
  },
  "then": {
    "required": ["contractId", "status", "timestamps"]
  },
  "properties": {
    "schemaVersion": { "type": "string", "enum": ["3.0", "3.1", "3.2"] },
    "contractId": { "type": "string", "pattern": "^sig-.+" },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "paused", "completed", "closed", "archived"],
      "default": "draft"
    },
    "timestamps": {
      "type": "object",
      "required": ["createdAt"],
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "activatedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "archivedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "goal": { "type": "string", "minLength": 10 },
    "inScope": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "allowNewFilesUnder": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Directories where new files may be created"
    },
    "outOfScope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "verify"],
        "properties": {
          "id": { "type": "string", "pattern": "^AC[0-9]+$" },
          "description": { "type": "string" },
          "visibility": { "type": "string", "enum": ["visible", "holdout"] },
          "verify": {
            "oneOf": [
              {
                "type": "object",
                "required": ["type", "value"],
                "properties": {
                  "type": { "type": "string", "enum": ["command", "manual"] },
                  "value": { "type": "string" }
                },
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["steps"],
                "properties": {
                  "steps": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "capture": { "type": "string" }
                      },
                      "oneOf": [
                        {
                          "required": ["http"],
                          "properties": {
                            "http": {
                              "type": "object",
                              "required": ["method", "url"],
                              "properties": {
                                "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD"] },
                                "url": { "type": "string" },
                                "headers": { "type": "object", "additionalProperties": { "type": "string" } },
                                "body": {}
                              }
                            },
                            "capture": { "type": "string" }
                          }
                        },
                        {
                          "required": ["exec"],
                          "properties": {
                            "exec": {
                              "type": "object",
                              "required": ["argv"],
                              "properties": {
                                "argv": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
                              }
                            },
                            "capture": { "type": "string" }
                          }
                        },
                        {
                          "required": ["expect"],
                          "properties": {
                            "expect": {
                              "type": "object",
                              "properties": {
                                "json_path": { "type": "string" },
                                "equals": {},
                                "stdout_contains": { "type": "string" },
                                "stdout_matches": { "type": "string" },
                                "exit_code": { "type": "integer" },
                                "file_exists": { "type": "string" },
                                "source": { "type": "string" }
                              }
                            },
                            "capture": { "type": "string" }
                          }
                        }
                      ]
                    },
                    "minItems": 1
                  },
                  "timeout_ms": { "type": "integer", "minimum": 0 }
                },
                "additionalProperties": false
              }
            ]
          }
        }
      },
      "minItems": 1
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" }
        }
      }
    },
    "openQuestions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "holdoutScenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "verify": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["command"] },
              "value": { "type": "string" }
            }
          }
        }
      },
      "description": "Hidden acceptance criteria not shown to Engineer"
    },
    "riskLevel": { "type": "string", "enum": ["low", "medium", "high"] },
    "riskSignals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiredInputsProvided": { "type": "boolean" },
    "trust": { "type": "string", "enum": ["local"] },
    "holdoutManifest": {
      "type": "object",
      "required": ["count", "hash"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "hash": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
