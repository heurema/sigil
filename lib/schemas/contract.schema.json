{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["schemaVersion", "goal", "inScope", "acceptanceCriteria", "riskLevel"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "2.0" },
    "goal": { "type": "string", "minLength": 10 },
    "inScope": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "outOfScope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "verify"],
        "properties": {
          "id": { "type": "string", "pattern": "^AC[0-9]+$" },
          "description": { "type": "string" },
          "verify": {
            "type": "object",
            "required": ["type", "value"],
            "properties": {
              "type": { "type": "string", "enum": ["command", "manual"] },
              "value": { "type": "string" }
            }
          }
        }
      },
      "minItems": 1
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" }
        }
      }
    },
    "openQuestions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "riskLevel": { "type": "string", "enum": ["low", "medium", "high"] },
    "riskSignals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiredInputsProvided": { "type": "boolean" }
  }
}
